{
  "name": "phantom-labs-substrate",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered UX simulation and forensic analysis infrastructure — Load testing for human behavior.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "quality:audit": "turbo run lint typecheck build --filter=@phantom-labs/dashboard",
    "vercel-build": "turbo run build --filter=@phantom-labs/dashboard",
    "build:substrate": "npm run build --workspace=@phantom-labs/substrate"
  },
  "devDependencies": {
    "@notionhq/client": "^5.15.0",
    "dotenv": "^17.3.1",
    "node-fetch": "^3.3.2",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.9.0",
  "author": "Vedant Kumar",
  "license": "MIT"
}

{
  "name": "phantom-labs-substrate",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered UX simulation and forensic analysis infrastructure — Load testing for human behavior.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev --workspace=@phantom-labs/dashboard",
    "dev:engine": "cd apps/core-engine && venv_new/Scripts/uvicorn app.main:app --reload --port 8000",
    "build:dashboard": "npm run build --workspace=@phantom-labs/dashboard",
    "test:engine": "cd apps/core-engine && venv_new/Scripts/python -m pytest apps/core-engine/tests",
    "test:dashboard": "npm run test --workspace=@phantom-labs/dashboard",
    "lint:dashboard": "npm run lint --workspace=@phantom-labs/dashboard"
  },
  "author": "Vedant Kumar",
  "license": "MIT"
}
